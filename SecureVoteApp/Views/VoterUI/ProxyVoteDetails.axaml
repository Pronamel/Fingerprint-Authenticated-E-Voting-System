<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:SecureVoteApp.ViewModels"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="380"
            x:Class="SecureVoteApp.Views.VoterUI.ProxyVoteDetailsView"
            x:DataType="vm:ProxyVoteDetailsViewModel">

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#F5FBFF"/>
            <Setter Property="Foreground" Value="#1B262C"/>
            <Setter Property="BorderBrush" Value="#3282B8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CaretBrush" Value="#0F4C75"/>
        </Style>

        <Style Selector="DatePicker">
            <Setter Property="Background" Value="#F5FBFF"/>
            <Setter Property="Foreground" Value="#1B262C"/>
            <Setter Property="BorderBrush" Value="#3282B8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinHeight" Value="44"/>
        </Style>
    </UserControl.Styles>

    <Design.DataContext>
        <vm:ProxyVoteDetailsViewModel/>
    </Design.DataContext>

    <Grid Background="#BBE1FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,16,0,8" Spacing="4">
            <TextBlock Text="Proxy Vote Identity Check"
                       FontSize="30"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="#1B262C"/>
            <TextBlock Text="Confirm represented voter and proxy details"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Foreground="#0F4C75"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid HorizontalAlignment="Center" Margin="18,6,18,18" MaxWidth="860">
                <Border Background="#D8ECFB"
                        BorderBrush="#3282B8"
                        BorderThickness="2"
                        CornerRadius="16"
                        Padding="24"
                        MinWidth="720"
                        VerticalAlignment="Top">
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="28">
                                <Border Grid.Column="0"
                                    Background="#EAF6FF"
                                    BorderBrush="#3282B8"
                                    BorderThickness="1.5"
                                    CornerRadius="12"
                                    Padding="16">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Represented Voter"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#1B262C"/>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="First Name" FontWeight="SemiBold" Foreground="#1B262C"/>
                                        <TextBox MinHeight="44"
                                                 HorizontalAlignment="Stretch"
                                                 Text="{Binding RepresentedFirstName}"
                                                 IsEnabled="{Binding !IsLooking}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Last Name" FontWeight="SemiBold" Foreground="#1B262C"/>
                                        <TextBox MinHeight="44"
                                                 HorizontalAlignment="Stretch"
                                                 Text="{Binding RepresentedLastName}"
                                                 IsEnabled="{Binding !IsLooking}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Date Of Birth" FontWeight="SemiBold" Foreground="#1B262C"/>
                                        <DatePicker MinHeight="44"
                                                    Height="44"
                                                    HorizontalAlignment="Stretch"
                                                    SelectedDate="{Binding RepresentedDateOfBirth}"
                                                    IsEnabled="{Binding !IsLooking}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Post Code" FontWeight="SemiBold" Foreground="#1B262C"/>
                                        <TextBox MinHeight="44"
                                                 HorizontalAlignment="Stretch"
                                                 Text="{Binding RepresentedPostCode}"
                                                 IsEnabled="{Binding !IsLooking}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Town Of Birth" FontWeight="SemiBold" Foreground="#1B262C"/>
                                        <TextBox MinHeight="44"
                                                 HorizontalAlignment="Stretch"
                                                 Text="{Binding RepresentedTownOfBirth}"
                                                 IsEnabled="{Binding !IsLooking}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                                <Border Grid.Column="1"
                                    Background="#EAF6FF"
                                    BorderBrush="#3282B8"
                                    BorderThickness="1.5"
                                    CornerRadius="12"
                                    Padding="16">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Proxy Voter"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#1B262C"/>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="First Name" FontWeight="SemiBold" Foreground="#1B262C"/>
                                        <TextBox MinHeight="44"
                                                 HorizontalAlignment="Stretch"
                                                 Text="{Binding ProxyFirstName}"
                                                 IsEnabled="{Binding !IsLooking}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Last Name" FontWeight="SemiBold" Foreground="#1B262C"/>
                                        <TextBox MinHeight="44"
                                                 HorizontalAlignment="Stretch"
                                                 Text="{Binding ProxyLastName}"
                                                 IsEnabled="{Binding !IsLooking}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Date Of Birth" FontWeight="SemiBold" Foreground="#1B262C"/>
                                        <DatePicker MinHeight="44"
                                                    Height="44"
                                                    HorizontalAlignment="Stretch"
                                                    SelectedDate="{Binding ProxyDateOfBirth}"
                                                    IsEnabled="{Binding !IsLooking}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Post Code" FontWeight="SemiBold" Foreground="#1B262C"/>
                                        <TextBox MinHeight="44"
                                                 HorizontalAlignment="Stretch"
                                                 Text="{Binding ProxyPostCode}"
                                                 IsEnabled="{Binding !IsLooking}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Town Of Birth" FontWeight="SemiBold" Foreground="#1B262C"/>
                                        <TextBox MinHeight="44"
                                                 HorizontalAlignment="Stretch"
                                                 Text="{Binding ProxyTownOfBirth}"
                                                 IsEnabled="{Binding !IsLooking}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <ProgressBar IsIndeterminate="True"
                                     IsVisible="{Binding IsLooking}"
                                     Height="8"/>

                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2,0,0">
                            <Button Content="Back"
                                    Grid.Column="0"
                                    Width="108"
                                    Height="44"
                                    Background="#3282B8"
                                    Foreground="White"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    CornerRadius="10"
                                    Command="{Binding BackCommand}"
                                    IsEnabled="{Binding !IsLooking}">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover">
                                        <Setter Property="Background" Value="#0F4C75"/>
                                    </Style>
                                </Button.Styles>
                            </Button>

                            <Button Content="Authenticate"
                                    Grid.Column="2"
                                    Width="168"
                                    Height="44"
                                    Background="#0F4C75"
                                    Foreground="White"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    CornerRadius="10"
                                    Command="{Binding AuthenticateCommand}"
                                    IsEnabled="{Binding !IsLooking}">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover">
                                        <Setter Property="Background" Value="#1B262C"/>
                                    </Style>
                                </Button.Styles>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>