<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:SecureVoteApp.ViewModels"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="380"
            x:Class="SecureVoteApp.Views.VoterUI.PersonalOrProxyView"
            x:DataType="vm:PersonalOrProxyViewModel"
            
            >

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
            to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:PersonalOrProxyViewModel/>
    </Design.DataContext>
    

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#BBE1FA">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="320" Spacing="16" Margin="24">
                <TextBlock Text="Vote In Person"
                           FontSize="38"
                           FontWeight="Bold"
                           Foreground="#1B262C"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Choose this option if you are the registered voter and want to cast your ballot yourself."
                           FontSize="18"
                           Foreground="#1B262C"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,18"/>

                <Button Command="{Binding OpenNINEntryCommand}"
                        Content="Personal Vote"
                        Background="#1B262C"
                        Foreground="#BBE1FA"
                        Width="250"
                        Height="76"
                        HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                        BorderThickness="2"
                        BorderBrush="#0F4C75"
                    FontSize="20"
                        FontWeight="SemiBold"
                        CornerRadius="14">
                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#BBE1FA"/>
                            <Setter Property="Foreground" Value="#1B262C"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="#0F4C75">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="320" Spacing="16" Margin="24">
                <TextBlock Text="Vote By Proxy"
                           FontSize="38"
                           FontWeight="Bold"
                           Foreground="#F2F7FB"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Choose this option when an approved proxy is voting on behalf of a registered voter."
                           FontSize="18"
                           Foreground="#F2F7FB"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,18"/>

                <Button Command="{Binding OpenProxyVoteCommand}"
                        Content="Proxy Vote"
                        Background="#BBE1FA"
                        Foreground="#1B262C"
                        Width="250"
                        Height="76"
                        HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                        BorderThickness="2"
                        BorderBrush="#3282B8"
                    FontSize="20"
                        FontWeight="SemiBold"
                        CornerRadius="14">
                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#1B262C"/>
                            <Setter Property="Foreground" Value="#BBE1FA"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>