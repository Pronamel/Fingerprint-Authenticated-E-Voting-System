<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:SecureVoteApp.ViewModels"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="380"
            x:Class="SecureVoteApp.Views.VoterUI.NINEntryView"
            x:DataType="vm:NINEntryViewModel">

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#F5FBFF"/>
            <Setter Property="Foreground" Value="#1B262C"/>
            <Setter Property="BorderBrush" Value="#3282B8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CaretBrush" Value="#0F4C75"/>
        </Style>

        <Style Selector="DatePicker">
            <Setter Property="Background" Value="#F5FBFF"/>
            <Setter Property="Foreground" Value="#1B262C"/>
            <Setter Property="BorderBrush" Value="#3282B8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinHeight" Value="44"/>
        </Style>
    </UserControl.Styles>

    
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
            to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:NINEntryViewModel/>
    </Design.DataContext>

    <Grid Background="#BBE1FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,16,0,8" Spacing="4">
            <TextBlock Text="Enter Voter Details"
                       FontSize="30"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="#1B262C"/>
            <TextBlock Text="Confirm identity using the voter record"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Foreground="#0F4C75"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid HorizontalAlignment="Center" Margin="18,6,18,18" MaxWidth="860">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#D8ECFB"
                        BorderBrush="#3282B8"
                        BorderThickness="2"
                        CornerRadius="16"
                        Padding="24"
                        MinWidth="720">
                    <StackPanel Spacing="16">
                        <Grid IsVisible="{Binding DateOfBirthVisible}"
                            RowDefinitions="Auto,Auto,Auto"
                              ColumnDefinitions="*,*"
                              RowSpacing="14"
                              ColumnSpacing="16">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                                <TextBlock Text="First Name (e.g., John)"
                                           FontWeight="SemiBold"
                                           Foreground="#1B262C"/>
                                <TextBox MinHeight="44"
                                         Width="340"
                                         HorizontalAlignment="Stretch"
                                         Text="{Binding FirstName}"
                                         IsEnabled="{Binding !IsLooking}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                                <TextBlock Text="Last Name (e.g., Smith)"
                                           FontWeight="SemiBold"
                                           Foreground="#1B262C"/>
                                <TextBox MinHeight="44"
                                         Width="340"
                                         HorizontalAlignment="Stretch"
                                         Text="{Binding LastName}"
                                         IsEnabled="{Binding !IsLooking}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                                <TextBlock Text="Date of Birth"
                                           FontWeight="SemiBold"
                                           Foreground="#1B262C"/>
                                <DatePicker MinHeight="44"
                                            Height="44"
                                            Width="340"
                                            HorizontalAlignment="Stretch"
                                            SelectedDate="{Binding SelectedDateOfBirth}"
                                            IsEnabled="{Binding !IsLooking}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                                <TextBlock Text="Post Code (e.g., SW1A 1AA)"
                                           FontWeight="SemiBold"
                                           Foreground="#1B262C"/>
                                <TextBox MinHeight="44"
                                         Width="340"
                                         HorizontalAlignment="Stretch"
                                         Text="{Binding PostCode}"
                                         IsEnabled="{Binding !IsLooking}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="6">
                                <TextBlock Text="Town Of Birth (e.g., London)"
                                           FontWeight="SemiBold"
                                           Foreground="#1B262C"/>
                                <TextBox MinHeight="44"
                                         HorizontalAlignment="Stretch"
                                         Text="{Binding TownOfBirth}"
                                         IsEnabled="{Binding !IsLooking}"/>
                            </StackPanel>

                        </Grid>

                        <Border Background="#EAF6FF"
                                BorderBrush="#3282B8"
                                BorderThickness="1"
                                CornerRadius="10"
                            Padding="10"
                            IsVisible="{Binding HasStatusMessage}">
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#0F4C75"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2,0,0">
                            <Button Content="Back"
                                    Grid.Column="0"
                                    Width="108"
                                    Height="44"
                                    Background="#3282B8"
                                    Foreground="White"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    CornerRadius="10"
                                    Command="{Binding BackCommand}"
                                    IsEnabled="{Binding !IsLooking}">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover">
                                        <Setter Property="Background" Value="#0F4C75"/>
                                    </Style>
                                </Button.Styles>
                            </Button>

                            <Button Content="Authenticate"
                                    Grid.Column="2"
                                    Width="168"
                                    Height="44"
                                    Background="#0F4C75"
                                    Foreground="White"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    CornerRadius="10"
                                    Command="{Binding ContinueCommand}"
                                    IsEnabled="{Binding !IsLooking}">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover">
                                        <Setter Property="Background" Value="#1B262C"/>
                                    </Style>
                                </Button.Styles>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,14,0,0"
                        Padding="16"
                        CornerRadius="14"
                        Background="#8B0A22"
                        BorderBrush="#4D0010"
                        BorderThickness="3"
                        IsVisible="{Binding ShowAlreadyVotedMessage}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Already Voted"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#FFE9ED"
                                   TextAlignment="Center"/>

                        <TextBlock Text="{Binding AlreadyVotedMessage}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#FFFFFF"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>

                        <TextBlock Text="Please speak to an official for assistance."
                                   FontSize="14"
                                   Foreground="#FFD8DF"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>

    
        



</UserControl>