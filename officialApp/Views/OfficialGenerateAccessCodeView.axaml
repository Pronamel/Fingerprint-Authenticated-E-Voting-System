<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:officialApp.ViewModels"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
            x:Class="officialApp.Views.OfficialGenerateAccessCodeView"
            x:DataType="vm:OfficialGenerateAccessCodeViewModel">

    <Design.DataContext>
        <vm:OfficialGenerateAccessCodeViewModel/>
    </Design.DataContext>

    <Grid Background="{StaticResource NavBackgroundBrush}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20" Width="400" Margin="20">
            
            <!-- Title -->
            <TextBlock Text="Generate Access Code" 
                      FontSize="24" 
                      FontWeight="Bold" 
                      Foreground="Black"
                      HorizontalAlignment="Center"/>
            
            <!-- Description -->
            <TextBlock Text="Enter an access code that voters will use to join your polling station." 
                      TextWrapping="Wrap"
                      Foreground="Black"
                      FontSize="14"
                      HorizontalAlignment="Center"/>
            

            <!-- Custom colored background and border for access code entry -->
            <Border Background="#285A48" CornerRadius="10" Padding="6">
                <Border Background="#408A71"
                        BorderBrush="#285A48"
                        BorderThickness="2"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <!-- Input Field -->
                        <StackPanel Spacing="5">
                            <TextBlock Text="Access Code (e.g., BRAINTREE-2026):" Foreground="Black" FontSize="16"/>
                            <TextBox x:Name="AccessCodeInput"
                                    Text="{Binding AccessCode}"
                                    Height="40"
                                    FontSize="14"
                                    Foreground="#285A48"
                                    Background="#E0F5EC"
                                    Padding="10"/>
                        </StackPanel>

                        <!-- Status Message -->
                        <TextBlock x:Name="StatusMessage"
                                  Text="{Binding StatusMessage}"
                                  TextWrapping="Wrap"
                                  Foreground="White"
                                  FontSize="12"
                                  HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Border>
            
            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center" Margin="0,20,0,0">
                
                <Button 
                    Command="{Binding GenerateCommand}"
                    Background="#285A48"  
                    Width="120"
                    Height="50" 
                    BorderThickness="2"
                    BorderBrush="Black"
                    FontSize="16">
                    <TextBlock Text="Generate" Foreground="white"/>
                </Button>
                
            </StackPanel>
            
        </StackPanel>

        <Button Content="← Back"
            Command="{Binding CancelCommand}"
            Padding="10,5"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="10"
            Background="#408A71"
            Foreground="White"/>
    </Grid>
</UserControl>
