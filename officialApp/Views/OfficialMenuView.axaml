<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:officialApp.ViewModels"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="380"
            x:Class="officialApp.Views.OfficialMenuView"
            x:DataType="vm:OfficialMenuViewModel">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
            to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:OfficialMenuViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto">

        <!-- 3x2 Checkerboard Grid: Dark-Light-Dark / Light-Dark-Light -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*,*" RowDefinitions="*,*">

            <!-- Row 0, Col 0: DARK -->
            <Button Grid.Row="0" Grid.Column="0"
                    Command="{Binding VotingStartCommand}"
                    Background="#285A48"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    BorderThickness="0"
                    CornerRadius="0">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" MaxWidth="220">
                    <TextBlock Text="Generate Access Code" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="Issue a code for voters to join your polling station" FontSize="13" Foreground="#B0E4CC" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Row 0, Col 1: LIGHT -->
            <Button Grid.Row="0" Grid.Column="1"
                    Command="{Binding ManagerCommand}"
                    Background="#B0E4CC"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    BorderThickness="0"
                    CornerRadius="0">
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#7BBFAC"/>
                    </Style>
                </Button.Styles>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" MaxWidth="220">
                    <TextBlock Text="Polling System Management" FontSize="22" FontWeight="Bold" Foreground="#091413" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="Monitor connected devices and polling stations" FontSize="13" Foreground="#285A48" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Row 0, Col 2: DARK -->
            <Button Grid.Row="0" Grid.Column="2"
                    Command="{Binding StatisticsCommand}"
                    Background="#285A48"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    BorderThickness="0"
                    CornerRadius="0">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" MaxWidth="220">
                    <TextBlock Text="Election Statistics" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="View live voting data and turnout rates" FontSize="13" Foreground="#B0E4CC" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Row 1, Col 0: LIGHT -->
            <Button Grid.Row="1" Grid.Column="0"
                    Command="{Binding ReportsCommand}"
                    Background="#B0E4CC"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    BorderThickness="0"
                    CornerRadius="0">
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#7BBFAC"/>
                    </Style>
                </Button.Styles>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" MaxWidth="220">
                    <TextBlock Text="Create User" FontSize="22" FontWeight="Bold" Foreground="#091413" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="Register a new voter or official account" FontSize="13" Foreground="#285A48" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Row 1, Col 1: DARK -->
            <Button Grid.Row="1" Grid.Column="1"
                    Command="{Binding AssignProxyCommand}"
                    Background="#285A48"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    BorderThickness="0"
                    CornerRadius="0">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" MaxWidth="220">
                    <TextBlock Text="Assign Proxy Voter" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="Assign a proxy to vote on behalf of a registered voter" FontSize="13" Foreground="#B0E4CC" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Row 1, Col 2: LIGHT -->
            <Button Grid.Row="1" Grid.Column="2"
                    Command="{Binding DuplicateFingerprintScanCommand}"
                    Background="#B0E4CC"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    BorderThickness="0"
                    CornerRadius="0">
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#7BBFAC"/>
                    </Style>
                </Button.Styles>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" MaxWidth="220">
                    <TextBlock Text="Duplicate Fingerprint Scan" FontSize="22" FontWeight="Bold" Foreground="#091413" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="Detect duplicate biometric records in the system" FontSize="13" Foreground="#285A48" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Bottom bar: status + logout -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,10,0,10">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{Binding StatusColor}"
                       VerticalAlignment="Center"
                       FontSize="12"/>
            <Button Command="{Binding LogoutCommand}"
                    Background="{StaticResource BannerBrush}"
                    Width="120"
                    Height="40"
                    BorderThickness="2"
                    BorderBrush="Black"
                    FontSize="14">
                <TextBlock Text="Logout" Foreground="White" FontWeight="Bold"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>