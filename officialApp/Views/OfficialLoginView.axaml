<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:officialApp.ViewModels"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="430"
            x:Class="officialApp.Views.OfficialLoginView"
            x:DataType="vm:OfficialLoginViewModel">

    <Design.DataContext>
        <vm:OfficialLoginViewModel/>
    </Design.DataContext>

    <Grid Background="#B0E4CC">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20" Width="350">
            
            <!-- Login Title -->
            <TextBlock Text="Official Login" 
                       FontSize="32" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center" 
                       Foreground="Black"
                       Margin="0,0,0,10"/>

            <!-- Username Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Username (e.g., official.j.smith)" 
                           FontSize="18" 
                           FontWeight="SemiBold"
                           Foreground="Black"/>
                <TextBox Name="UsernameTextBox"
                         Text="{Binding Username}"
                         Background="#E0F5EC"
                         BorderBrush="Gray"
                         BorderThickness="2"
                         CornerRadius="5"
                         Padding="10"
                         FontSize="14"
                         Foreground="#285A48"
                         Height="40"/>
            </StackPanel>

            <!-- Password Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Password (e.g., SecurePass!2026)" 
                           FontSize="18" 
                           FontWeight="SemiBold"
                           Foreground="Black"/>
                <TextBox Name="PasswordTextBox"
                         Text="{Binding Password}"
                         PasswordChar="*"
                         Background="#E0F5EC"
                         BorderBrush="Gray"
                         BorderThickness="2"
                         CornerRadius="5"
                         Padding="10"
                         FontSize="14"
                         Foreground="#285A48"
                         Height="40"/>
            </StackPanel>

            <!-- Login Status -->
            <TextBlock Text="{Binding LoginStatus}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="Black"
                       Margin="0,10,0,0"
                       TextWrapping="Wrap"/>

            <!-- Login Button -->
            <Button Command="{Binding AuthenticateCommand}"
                    Content="Login"
                    IsEnabled="{Binding CanLogin}"
                    Background="#285A48"
                    Foreground="White"
                    FontSize="16"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    Padding="30,12"
                    CornerRadius="8"
                    BorderThickness="2"
                    BorderBrush="#3E5F44"
                    Margin="0,20,0,0"
                    Cursor="Hand">
                <Button.Styles>
                    <Style Selector="Button:pointerover">
                        <Setter Property="Background" Value="#3E5F44"/>
                    </Style>
                    <Style Selector="Button:disabled">
                        <Setter Property="Background" Value="#b3d9b3"/>
                        <Setter Property="Foreground" Value="#666666"/>
                        <Setter Property="BorderBrush" Value="#93DA97"/>
                    </Style>
                </Button.Styles>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>