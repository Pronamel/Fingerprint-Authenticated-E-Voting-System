<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:officialApp.ViewModels"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="1325" d:DesignHeight="1788"
            x:Class="officialApp.Views.OfficialAssignProxyView"
            x:DataType="vm:OfficialAssignProxyViewModel"
            Background="{StaticResource NavBackgroundBrush}">

    <Design.DataContext>
        <vm:OfficialAssignProxyViewModel/>
    </Design.DataContext>

    <Grid Background="{StaticResource NavBackgroundBrush}" RowDefinitions="Auto,*" Margin="20">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0"
                    Content="← Back"
                    Command="{Binding BackCommand}"
                    Padding="10,5"
                    VerticalAlignment="Center"
                    Background="{StaticResource AccentBrush1}"
                    Foreground="White"
                    HorizontalAlignment="Left"/>

            <TextBlock Grid.Column="1"
                       Text="Assign Proxy Voter"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="Black"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="0,18,0,0">
            <StackPanel Spacing="18">
                <TextBlock Text="Complete both identity panels, then scan the represented voter fingerprint to assign the proxy."
                           TextWrapping="Wrap"
                           FontSize="14"
                          Foreground="Black"
                           HorizontalAlignment="Center"/>

                <Grid ColumnDefinitions="3*,2*" ColumnSpacing="22">
                    <StackPanel Grid.Column="0" Spacing="14">
                        <Border Background="#285A48" CornerRadius="10" Padding="6">
                            <Border Background="#408A71"
                                    BorderBrush="#285A48"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Represented Voter" FontSize="18" FontWeight="Bold" Foreground="White"/>

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="First Name" FontSize="15" Foreground="Black"/>
                                            <TextBox Text="{Binding RepresentedFirstName}" Height="38" Padding="8" Foreground="#285A48" Background="#E0F5EC" FontSize="14"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Last Name" FontSize="15" Foreground="Black"/>
                                            <TextBox Text="{Binding RepresentedLastName}" Height="38" Padding="8" Foreground="#285A48" Background="#E0F5EC" FontSize="14"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Date of Birth" FontSize="15" Foreground="Black"/>
                                        <DatePicker SelectedDate="{Binding RepresentedDateOfBirth}" Height="38" Background="#E0F5EC" FontSize="14"/>
                                    </StackPanel>

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="Post Code" FontSize="15" Foreground="Black"/>
                                            <TextBox Text="{Binding RepresentedPostCode}" Height="38" Padding="8" Background="#E0F5EC" Foreground="#285A48" FontSize="14"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Town of Birth" FontSize="15" Foreground="Black"/>
                                            <TextBox Text="{Binding RepresentedTownOfBirth}" Height="38" Padding="8" Background="#E0F5EC" Foreground="#285A48" FontSize="14"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Border>

                        <Border Background="#285A48" CornerRadius="10" Padding="6">
                            <Border Background="#408A71"
                                    BorderBrush="#285A48"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Proxy Voter" FontSize="18" FontWeight="Bold" Foreground="White"/>

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="First Name" FontSize="15" Foreground="Black"/>
                                            <TextBox Text="{Binding ProxyFirstName}" Height="38" Padding="8" Foreground="#285A48" Background="#E0F5EC" FontSize="14"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Last Name" FontSize="15" Foreground="Black"/>
                                            <TextBox Text="{Binding ProxyLastName}" Height="38" Padding="8" Foreground="#285A48" Background="#E0F5EC" FontSize="14"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Date of Birth" FontSize="15" Foreground="Black"/>
                                        <DatePicker SelectedDate="{Binding ProxyDateOfBirth}" Height="38" Background="#E0F5EC" FontSize="14"/>
                                    </StackPanel>

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="Post Code" FontSize="15" Foreground="Black"/>
                                            <TextBox Text="{Binding ProxyPostCode}" Height="38" Padding="8" Background="#E0F5EC" Foreground="#285A48" FontSize="14"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Town of Birth" FontSize="15" Foreground="Black"/>
                                            <TextBox Text="{Binding ProxyTownOfBirth}" Height="38" Padding="8" Background="#E0F5EC" Foreground="#285A48" FontSize="14"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="12" VerticalAlignment="Top" Margin="0,24,0,0">
                        <TextBlock Text="Fingerprint Verification"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#6b4423"
                                   HorizontalAlignment="Center"/>

                        <Border Background="Black" Width="240" Height="240" HorizontalAlignment="Center" BorderThickness="0">
                            <Image Source="{Binding PreviewImage}" Width="240" Height="240" Stretch="Uniform"/>
                        </Border>

                        <TextBlock Text="{Binding CaptureStatusMessage}"
                                   FontSize="13"
                                   Foreground="#444"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding !IsCooldownActive}"/>

                        <TextBlock Text="{Binding CooldownSecondsRemaining, StringFormat='Scanner cooldown: {0}s'}"
                                   FontSize="13"
                                   Foreground="#e67e22"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   IsVisible="{Binding IsCooldownActive}"/>

                        <ProgressBar IsIndeterminate="True"
                                     IsVisible="{Binding IsCapturing}"
                                     Width="240"
                                     Height="8"
                                     HorizontalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <Button Content="Assign"
                                    Background="{StaticResource AccentBrush2}"
                                    Foreground="White"
                                    Width="120"
                                    Height="50"
                                    HorizontalAlignment="Center"
                                    FontWeight="Bold"
                                    BorderThickness="2"
                                    BorderBrush="Black"
                                    Command="{Binding AssignProxyCommand}"/>

                            <Button Content="Recapture"
                                    Background="{StaticResource AccentBrush1}"
                                    Foreground="White"
                                    Width="120"
                                    Height="50"
                                    HorizontalAlignment="Center"
                                    FontWeight="Bold"
                                    BorderThickness="2"
                                    BorderBrush="Black"
                                    Command="{Binding ReCaptureCommand}"
                                    IsEnabled="{Binding !IsCapturing}"/>
                        </StackPanel>

                        <TextBlock Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap"
                                   Foreground="{Binding StatusColor}"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>